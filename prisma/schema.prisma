generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  BARTENDER
  BUTCHER
  CLIENT
  KITCHEN
  VIP_BARTENDER
  WAITER
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  CLEANING
  WAITING_BILL
  CLOSED
}

enum OrderStatus {
  NEW
  PREPARING
  READY
  SERVED
  COMPLETED
  CANCELLED
  DELAYED
}

enum PaymentMethod {
  CASH
  CARD
  MOBILE_MONEY
  QR_CODE
  BANK_TRANSFER
  GIFT_CARD
  STORE_CREDIT
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum TicketStatus {
  NEW
  PREPARING
  READY
  SERVED
  COMPLETED
  CANCELLED
  DELAYED
  PAUSED
}

enum NotificationType {
  ORDER_READY
  ORDER_NEW
  ORDER_DELAYED
  LOW_STOCK
  TABLE_REQUEST
  PAYMENT_RECEIVED
  RESERVATION_REMINDER
  SYSTEM_ALERT
}

enum ActivityType {
  ORDER_CREATED
  ORDER_UPDATED
  ORDER_CANCELLED
  PAYMENT_PROCESSED
  TABLE_ASSIGNED
  TABLE_MERGED
  TABLE_SPLIT
  MENU_UPDATED
  INVENTORY_UPDATED
  EMPLOYEE_CREATED
  EMPLOYEE_UPDATED
  RESERVATION_CREATED
  RESERVATION_UPDATED
  DISCOUNT_APPLIED
  REFUND_PROCESSED
  LOGIN
  LOGOUT
}

model Restaurant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  email     String?
  phone     String?
  address   String?
  logo      String?
  currency  String   @default("USD")
  timezone  String   @default("UTC")
  taxRate   Float    @default(0.0)
  serviceCharge Float @default(0.0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branches   Branch[]
  users      User[]
  customers  Customer[]
  menuItems  MenuItem[]
  categories MenuCategory[]
  tables     RestaurantTable[]
  orders     Order[]
  payments   Payment[]
  receipts   Receipt[]
  inventoryItems InventoryItem[]
  suppliers  Supplier[]
  reservations Reservation[]
  discounts Discount[]
  roles      Role[]
  notifications Notification[]

  @@map("restaurants")
}

model Branch {
  id         String   @id @default(cuid())
  restaurantId String
  name       String
  address    String?
  phone      String?
  email      String?
  managerId  String?   @unique
  manager    User?     @relation("BranchManager", fields: [managerId], references: [id])
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  restaurant    Restaurant @relation(fields: [restaurantId], references: [id])
  tables        RestaurantTable[]
  orders        Order[]
  employees     User[]     @relation("BranchEmployees")
  inventoryItems InventoryItem[]
  receipts      Receipt[]
  reservations  Reservation[]

  @@map("branches")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  firstName     String
  lastName      String
  phone         String?
  avatar        String?
  roleId        String
  role          Role     @relation(fields: [roleId], references: [id])
  restaurantId  String
  restaurant    Restaurant @relation(fields: [restaurantId], references: [id])
  branchId      String?
  branch        Branch?  @relation("BranchEmployees", fields: [branchId], references: [id])
  managedBranch Branch?  @relation("BranchManager")
  isActive      Boolean  @default(true)
  lastLogin     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  orders           Order[]
  assignedTables   RestaurantTable[]
  notifications   Notification[]
  activityLogs    ActivityLog[]
  processedPayments Payment[]

  @@map("users")
}

model Role {
  id          String   @id @default(cuid())
  restaurantId String
  name        String
  description String?
  permissions Json     @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
  users      User[]

  @@unique([restaurantId, name])
  @@map("roles")
}

model Customer {
  id           String   @id @default(cuid())
  restaurantId String
  firstName    String
  lastName     String
  email        String?
  phone        String?
  address      String?
  birthday     DateTime?
  notes        String?
  totalVisits  Int      @default(0)
  totalSpent   Float    @default(0)
  loyaltyPoints Int     @default(0)
  favoriteItems String?  @default("[]")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant    Restaurant @relation(fields: [restaurantId], references: [id])
  orders        Order[]
  reservations  Reservation[]
  feedbacks     Feedback[]

  @@map("customers")
}

model MenuCategory {
  id           String   @id @default(cuid())
  restaurantId String
  name         String
  description  String?
  image        String?
  sortOrder    Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
  items      MenuItem[]

  @@map("menu_categories")
}

model MenuItem {
  id           String   @id @default(cuid())
  restaurantId String
  categoryId   String
  name         String
  description  String?
  price        Float
  comparePrice Float?
  cost         Float    @default(0)
  image        String?
  images       String?  @default("[]")
  isActive     Boolean  @default(true)
  isAvailable  Boolean  @default(true)
  isFeatured   Boolean  @default(false)
  preparationTime Int   @default(15)
  allergens    String?  @default("[]")
  ingredients  String?  @default("[]")
  nutritionalInfo String? @default("{}")
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  category     MenuCategory @relation(fields: [categoryId], references: [id])
  variants     MenuItemVariant[]
  extras       MenuItemExtra[]
  orderItems   OrderItem[]
  inventoryIngredients InventoryIngredient[]

  @@map("menu_items")
}

model MenuItemVariant {
  id        String @id @default(cuid())
  menuItemId String
  name      String
  price     Float
  isDefault Boolean @default(false)
  isAvailable Boolean @default(true)

  menuItem MenuItem @relation(fields: [menuItemId], references: [id])

  @@map("menu_item_variants")
}

model MenuItemExtra {
  id        String @id @default(cuid())
  menuItemId String
  name      String
  price     Float
  maxSelect Int     @default(1)

  menuItem MenuItem @relation(fields: [menuItemId], references: [id])

  @@map("menu_item_extras")
}

model RestaurantTable {
  id         String      @id @default(cuid())
  restaurantId String
  branchId   String?
  number     Int
  name       String?
  capacity   Int         @default(4)
  minCapacity Int        @default(1)
  shape      String      @default("rectangle")
  posX       Float       @default(0)
  posY       Float       @default(0)
  width      Float       @default(100)
  height     Float       @default(100)
  rotation   Float       @default(0)
  status     TableStatus @default(AVAILABLE)
  section    String?
  qrCode     String?
  waiterId   String?
  waiter     User?       @relation(fields: [waiterId], references: [id])
  isActive   Boolean     @default(true)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  branch       Branch?    @relation(fields: [branchId], references: [id])
  orders       Order[]
  reservations Reservation[]

  @@map("restaurant_tables")
}

model Order {
  id            String      @id @default(cuid())
  orderNumber   Int         @default(autoincrement())
  restaurantId  String
  branchId      String?
  tableId       String?
  table         RestaurantTable? @relation(fields: [tableId], references: [id])
  waiterId      String?
  waiter        User?       @relation(fields: [waiterId], references: [id])
  customerId    String?
  customer      Customer?   @relation(fields: [customerId], references: [id])
  status        OrderStatus @default(NEW)
  type          String      @default("DINE_IN")
  subtotal      Float       @default(0)
  taxAmount     Float       @default(0)
  serviceCharge Float       @default(0)
  discountAmount Float      @default(0)
  total         Float       @default(0)
  paidAmount    Float       @default(0)
  changeAmount  Float       @default(0)
  notes         String?
  customerNotes String?
  isPaid        Boolean     @default(false)
  isTakeaway    Boolean     @default(false)
  isDelivery    Boolean     @default(false)
  deliveryAddress String?
  guestCount    Int         @default(1)
  preparationTime Int       @default(0)
  completedAt   DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  restaurant  Restaurant @relation(fields: [restaurantId], references: [id])
  branch      Branch?    @relation(fields: [branchId], references: [id])
  items       OrderItem[]
  payments    Payment[]
  receipts    Receipt[]
  tickets     KitchenTicket[]
  activityLogs ActivityLog[]

  @@map("orders")
}

model OrderItem {
  id          String      @id @default(cuid())
  orderId     String
  menuItemId  String
  menuItem    MenuItem    @relation(fields: [menuItemId], references: [id])
  name        String
  quantity    Int         @default(1)
  unitPrice   Float
  totalPrice  Float
  variant     String?
  extras      String?     @default("[]")
  modifiers   String?     @default("[]")
  cookingNotes String?
  instructions String?
  status      String      @default("NEW")
  sortOrder   Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  order Order @relation(fields: [orderId], references: [id])

  @@map("order_items")
}

model KitchenTicket {
  id        String       @id @default(cuid())
  orderId   String
  ticketNumber Int       @default(autoincrement())
  status    TicketStatus @default(NEW)
  priority  Int          @default(0)
  station   String?
  preparedBy String?
  startedAt DateTime?
  completedAt DateTime?
  notes     String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  order Order @relation(fields: [orderId], references: [id])
  items KitchenTicketItem[]

  @@map("kitchen_tickets")
}

model KitchenTicketItem {
  id            String      @id @default(cuid())
  ticketId      String
  orderItemId   String
  name          String
  quantity      Int
  modifiers     String?     @default("[]")
  notes         String?
  status        TicketStatus @default(NEW)

  ticket KitchenTicket @relation(fields: [ticketId], references: [id])

  @@map("kitchen_ticket_items")
}

model Payment {
  id            String        @id @default(cuid())
  orderId       String
  restaurantId  String
  amount        Float
  tipAmount     Float         @default(0)
  method        PaymentMethod
  status        PaymentStatus @default(PENDING)
  reference     String?
  notes         String?
  processedById String?
  processedBy   User?         @relation(fields: [processedById], references: [id])
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  order      Order      @relation(fields: [orderId], references: [id])
  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
  receipt    Receipt?

  @@map("payments")
}

model Receipt {
  id         String   @id @default(cuid())
  paymentId  String   @unique
  receiptNumber String @unique
  orderId    String
  restaurantId String
  branchId   String?
  subtotal   Float
  taxAmount  Float
  serviceCharge Float @default(0)
  discountAmount Float @default(0)
  tipAmount  Float    @default(0)
  total      Float
  paidAmount Float
  changeAmount Float   @default(0)
  paymentMethods String @default("[]")
  items      String   @default("[]")
  emailSent  Boolean  @default(false)
  smsSent    Boolean  @default(false)
  printed    Boolean  @default(false)
  createdAt  DateTime @default(now())

  payment Payment @relation(fields: [paymentId], references: [id])
  order   Order   @relation(fields: [orderId], references: [id])
  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
  branch   Branch?  @relation(fields: [branchId], references: [id])

  @@map("receipts")
}

model InventoryItem {
  id            String   @id @default(cuid())
  restaurantId  String
  branchId      String?
  name          String
  sku           String?
  category      String?
  unit          String   @default("pieces")
  currentStock  Float    @default(0)
  minStock      Float    @default(10)
  maxStock      Float    @default(100)
  costPerUnit   Float    @default(0)
  sellingPrice  Float?
  barcode       String?
  expiryDate    DateTime?
  location      String?
  image         String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  restaurant  Restaurant @relation(fields: [restaurantId], references: [id])
  branch      Branch?    @relation(fields: [branchId], references: [id])
  ingredients InventoryIngredient[]
  stockMovements StockMovement[]

  @@map("inventory_items")
}

model InventoryIngredient {
  id              String @id @default(cuid())
  menuItemId      String
  inventoryItemId String
  quantity        Float

  menuItem      MenuItem      @relation(fields: [menuItemId], references: [id])
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])

  @@unique([menuItemId, inventoryItemId])
  @@map("inventory_ingredients")
}

model StockMovement {
  id              String   @id @default(cuid())
  inventoryItemId String
  type            String
  quantity        Float
  previousStock   Float
  newStock        Float
  reference       String?
  notes           String?
  userId          String?
  createdAt       DateTime @default(now())

  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])

  @@map("stock_movements")
}

model Supplier {
  id           String   @id @default(cuid())
  restaurantId String
  name         String
  contactName  String?
  email        String?
  phone        String?
  address      String?
  category     String?
  notes        String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  @@map("suppliers")
}

model Reservation {
  id           String   @id @default(cuid())
  restaurantId String
  branchId     String?
  tableId      String?
  table        RestaurantTable? @relation(fields: [tableId], references: [id])
  customerId   String?
  customer     Customer? @relation(fields: [customerId], references: [id])
  guestName    String?
  guestPhone   String?
  guestEmail   String?
  guestCount   Int
  dateTime     DateTime
  duration     Int      @default(120)
  notes        String?
  status       String   @default("PENDING")
  source       String   @default("MANUAL")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
  branch     Branch?    @relation(fields: [branchId], references: [id])

  @@map("reservations")
}

model Discount {
  id           String   @id @default(cuid())
  restaurantId String
  code         String?
  name         String
  type         String
  value        Float
  minOrder     Float    @default(0)
  maxUses      Int?
  usedCount    Int      @default(0)
  isActive     Boolean  @default(true)
  startsAt     DateTime?
  endsAt       DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  @@map("discounts")
}

model Feedback {
  id         String   @id @default(cuid())
  customerId String
  orderId    String?
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id])

  @@map("feedbacks")
}

model Notification {
  id         String           @id @default(cuid())
  restaurantId String
  userId     String?
  user       User?            @relation(fields: [userId], references: [id])
  type       NotificationType
  title      String
  message    String
  data       String?
  isRead     Boolean          @default(false)
  actionUrl  String?
  createdAt  DateTime         @default(now())

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  @@map("notifications")
}

model ActivityLog {
  id         String       @id @default(cuid())
  restaurantId String
  orderId    String?
  userId     String?
  user       User?        @relation(fields: [userId], references: [id])
  order      Order?       @relation(fields: [orderId], references: [id])
  type       ActivityType
  description String
  entityType String?
  entityId   String?
  metadata   String?      @default("{}")
  createdAt  DateTime     @default(now())

  @@map("activity_logs")
}
